# ============ MySQL ============
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=blogshare
MYSQL_PASSWORD=changeme_strong_password
MYSQL_DATABASE=blogshare
MYSQL_ROOT_PASSWORD=changeme_root_password

# ============ Redis ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_DB=0
# 完整连接 URL（供后端 redis.asyncio 使用）
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# ============ Backend ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
# 前端来源（CORS 白名单，逗号分隔）
CORS_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1

# ============ JWT ============
JWT_SECRET_KEY=please_change_this_to_a_random_long_string_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ Frontend ============
VITE_API_BASE_URL=/api/v1
